// 水ドット描画用の材質別カラーパレット（sRGB 8bit）
// 各材質4色をドットごとに擬似乱数で選択する。
(
    water: (
        colors: (
            (r: 42, g: 120, b: 202),
            (r: 52, g: 136, b: 218),
            (r: 65, g: 152, b: 228),
            (r: 78, g: 167, b: 238),
        ),
    ),
    soil: (
        colors: (
            (r: 112, g: 86, b: 61),
            (r: 126, g: 97, b: 69),
            (r: 144, g: 112, b: 79),
            (r: 163, g: 128, b: 92),
        ),
    ),
    sand: (
        colors: (
            (r: 156, g: 134, b: 94),
            (r: 172, g: 148, b: 104),
            (r: 189, g: 163, b: 115),
            (r: 205, g: 178, b: 126),
        ),
    ),
)
