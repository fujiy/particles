// 水ドット描画用の材質別カラーパレット（sRGB 8bit）
// 各材質4色をドットごとに擬似乱数で選択する。
(
    water: (
        colors: (
            "#2A78CA",
            "#3488DA",
            "#4198E4",
            "#4EA7EE",
        ),
    ),
    soil: (
        colors: (
            "#70563D",
            "#7E6145",
            "#90704F",
            "#A3805C",
        ),
    ),
    sand: (
        colors: (
            "#9C865E",
            "#AC9468",
            "#BDA373",
            "#CDB27E",
        ),
    ),
)
