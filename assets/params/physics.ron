// GPU MPM 物性・境界・連成パラメータ
// 実行中に編集してホットリロード可能。不正値は無視され直前の有効値を維持する。
//
// 対応 Rust 型: particles::params::physics::PhysicsParams
(
    // 水の状態方程式 [Eq.7, physics.md]
    water: (
        // 基準密度 ρ₀ [kg/m³]. 許容: 100.0 – 10000.0
        rho0: 1000.0,
        // 音速 c₀ [m/s]. bulk_modulus = ρ₀·c₀² で計算. 許容: 1.0 – 1000.0
        sound_speed_mps: 16.0,
    ),

    // 変形勾配クランプ
    deformation: (
        // J = det(F) の下限. 許容: 0.01 – 1.0
        j_min: 0.6,
        // J の上限. 許容: 1.0 – 10.0
        j_max: 1.4,
        // C マトリクスのノルム上限. 許容: 1.0 – 1000.0
        c_max_norm: 80.0,
    ),

    // APIC ↔ PIC ブレンド [Eq.32, physics.md]
    apic: (
        // 水. 1.0 = 完全 APIC, 0.0 = 完全 PIC. 許容: 0.0 – 1.0
        water: 0.99,
        // 粉体. 許容: 0.0 – 1.0
        granular: 0.78,
    ),

    // 地形境界 Coulomb 摩擦 [Eq.29, physics.md]
    boundary: (
        // 水の摩擦係数 μ_b. 許容: 0.0 – 2.0
        water: 0.1,
        // 粉体の摩擦係数 μ_b. 許容: 0.0 – 2.0
        granular: 0.6,
    ),

    // Drucker-Prager 土壌パラメータ
    soil: (
        // ヤング率 E [Pa]. 許容: 1.0 – 1e8
        youngs_modulus_pa: 800.0,
        // ポアソン比 ν. 許容: 0.0 – 0.45
        poisson_ratio: 0.28,
        // 内部摩擦角 φ [度]. 許容: 0.0 – 60.0
        friction_deg: 36.0,
        // 凝着力 c [Pa]. 許容: 0.0 – 1e6
        cohesion_pa: 0.0,
        // 硬化係数 h. 許容: 0.0 – 10.0
        hardening: 0.0,
    ),

    // Drucker-Prager 砂パラメータ
    sand: (
        // ヤング率 E [Pa]. 許容: 1.0 – 1e8
        youngs_modulus_pa: 700.0,
        // ポアソン比 ν. 許容: 0.0 – 0.45
        poisson_ratio: 0.25,
        // 内部摩擦角 φ [度]. 許容: 0.0 – 60.0
        friction_deg: 34.0,
        // 凝着力 c [Pa]. 許容: 0.0 – 1e6
        cohesion_pa: 0.0,
        // 硬化係数 h. 許容: 0.0 – 10.0
        hardening: 0.0,
    ),

    // 粉体の引張クランプ [Pa]. 0.0 = 無効. 許容: 0.0 – 1e5
    granular_tensile_clamp: 0.0,

    // 水-粉体連成パラメータ
    coupling: (
        // 法線方向スティフネス. 許容: 0.0 – 10.0
        normal_stiffness: 0.55,
        // 接線方向ドラッグ. 許容: 0.0 – 10.0
        tangent_drag: 0.30,
        // 連成摩擦係数. 許容: 0.0 – 2.0
        friction: 0.45,
        // 最大インパルス比. 許容: 0.0 – 1.0
        max_impulse_ratio: 0.50,
    ),
)
